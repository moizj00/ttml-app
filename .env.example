# ─── Database ───
DATABASE_URL=postgresql://user:password@localhost:5432/ttml

# ─── Supabase Auth ───
SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VITE_SUPABASE_ANON_KEY=your-anon-key
# Fallback if VITE_SUPABASE_ANON_KEY is not set (used by some frontend builds)
# VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# ─── Auth / Session ───
JWT_SECRET=your-jwt-secret

# ─── AI Pipeline ───
ANTHROPIC_API_KEY=sk-ant-...       # Required — assembly/vetting + drafting fallback
OPENAI_API_KEY=sk-...              # Required — research (primary) + embeddings
PERPLEXITY_API_KEY=pplx-...        # Required — sole research provider (fail-hard)

# ─── n8n Integration (optional) ───
N8N_WEBHOOK_URL=
N8N_CALLBACK_SECRET=
# N8N_PRIMARY=true  # Set to use n8n as primary pipeline (dormant — do NOT enable in prod untested)

# ─── Email (Resend) ───
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@talk-to-my-lawyer.com

# ─── Cloudflare Email Worker (optional) ───
EMAIL_WORKER_URL=
EMAIL_WORKER_SECRET=

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_...

# ─── Upstash Redis (rate limiting — fail-open when absent) ───
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token
UPSTASH_REDIS_URL=rediss://default:token@your-redis.upstash.io:6379

# ─── pg-boss (PostgreSQL-native job queue) ───
# Falls back to DATABASE_URL if not set. Use direct connection (port 5432) for reliability.
SUPABASE_DIRECT_URL=postgresql://postgres:password@db.ref.supabase.co:5432/postgres

# ─── Sentry (optional) ───
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Cloudflare R2 (file storage) ───
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=ttml-attachments
R2_PUBLIC_URL=

# ─── Cloudflare KV Cache (optional) ───
KV_WORKER_URL=
KV_WORKER_AUTH_TOKEN=

# ─── Cloudflare Workers (optional) ───
AFFILIATE_WORKER_URL=https://refer.talktomylawyer.com
AFFILIATE_WORKER_SECRET=
CF_BLOG_CACHE_WORKER_URL=
CF_BLOG_CACHE_INVALIDATION_SECRET=
PDF_WORKER_URL=
PDF_WORKER_SECRET=

# ─── GCP / Vertex AI (optional — training & fine-tuning) ───
GCP_PROJECT_ID=
GCP_REGION=
GCS_TRAINING_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Vertex AI Search (optional — RAG / legal research) ───
VERTEX_SEARCH_INDEX_ID=
VERTEX_SEARCH_INDEX_ENDPOINT_ID=
VERTEX_SEARCH_DEPLOYED_INDEX_ID=

# ─── Forge API (optional — built-in integrations) ───
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
