# Runtime
NODE=production
NODE_ENV=production
NODE_OPTIONS=--dns-result-order=ipv4first
APP_BASE_URL=https://www.example.com
STAGING_APP_BASE_URL=https://staging.example.com
WORKER_HEALTH_PORT=8080

# Database / Supabase
DATABASE_URL=postgresql://user:password@host:5432/database
SUPABASE_DATABASE_URL=postgresql://user:password@host:5432/database
SUPABASE_DIRECT_URL=postgresql://user:password@host:5432/database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Auth / Sessions
JWT_SECRET=your-jwt-secret
CRON_SECRET=your-cron-secret

# AI Providers
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key
RAG_AB_TEST_CONTROL_PCT=10

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
VITE_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Email
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@example.com

# Redis / Upstash
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
UPSTASH_REDIS_URL=rediss://default:token@your-redis.upstash.io:6379

# n8n
N8N_PRIMARY=false
N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/path
N8N_CALLBACK_SECRET=your-n8n-callback-secret

# Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_URL=https://your-r2-public-url.example.com

# Sentry
SENTRY_DSN=https://example@sentry.io/project
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
VITE_SENTRY_DSN=https://example@sentry.io/project

# Google / GCP
VITE_GOOGLE_API_KEY=your-google-api-key
CLIENT_ID=your-google-client-id
CLIENT_SECRET=your-google-client-secret
REFRESH_TOKEN=your-google-refresh-token
TYPE=authorized_user
UNIVERSE_DOMAIN=googleapis.com
quota_project_id=your-gcp-quota-project-id
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-west1
GCS_TRAINING_BUCKET=your-gcs-training-bucket

# Deployment / Platform
RAILWAY_TOKEN=your-railway-token
