# ─── Database ───
DATABASE_URL=postgresql://user:password@localhost:5432/ttml

# ─── Supabase Auth ───
SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VITE_SUPABASE_ANON_KEY=your-anon-key
# Fallback if VITE_SUPABASE_ANON_KEY is not set (used by some frontend builds)
# VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# ─── Auth / Session ───
JWT_SECRET=your-jwt-secret

# ─── AI Pipeline ───
ANTHROPIC_API_KEY=sk-ant-...       # Required — assembly/vetting + drafting fallback
OPENAI_API_KEY=sk-...              # Required — research (primary) + embeddings
PERPLEXITY_API_KEY=pplx-...        # Required — sole research provider (fail-hard)

# ─── n8n Integration (optional) ───
N8N_WEBHOOK_URL=
N8N_CALLBACK_SECRET=
# N8N_PRIMARY=true  # Set to use n8n as primary pipeline (dormant — do NOT enable in prod untested)

# ─── Email (Resend) ───
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@talk-to-my-lawyer.com

# ─── Cloudflare Email Worker (optional) ───
EMAIL_WORKER_URL=
EMAIL_WORKER_SECRET=

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_...

# ─── Upstash Redis (rate limiting — fail-open when absent) ───
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token
UPSTASH_REDIS_URL=rediss://default:token@your-redis.upstash.io:6379

# ─── pg-boss (PostgreSQL-native job queue) ───
# Falls back to DATABASE_URL if not set. Use direct connection (port 5432) for reliability.
SUPABASE_DIRECT_URL=postgresql://postgres:password@db.ref.supabase.co:5432/postgres

# ─── Worker Configuration ───
# Number of concurrent pipeline workers (1-5, default 2). Higher = faster throughput
# but more CPU/RAM. In single-container mode (PROCESS_TYPE=all), leave headroom for
# the web server. Monitor /health/details for CPU% before increasing.
# WORKER_CONCURRENCY=2

# Alert admins when queue depth exceeds this threshold (default 10). Set higher if you
# expect burst submissions. Zero disables alerting.
# QUEUE_BACKLOG_THRESHOLD=10

# ─── Pipeline Stage Timeouts (P3) ───
# Per-stage timeout in ms. Total max pipeline duration = sum of all stages (default 45min).
# Increase if your AI providers are slow. Decrease to fail faster on stuck stages.
# PIPELINE_RESEARCH_TIMEOUT_MS=600000     # 10 min
# PIPELINE_DRAFTING_TIMEOUT_MS=900000     # 15 min
# PIPELINE_ASSEMBLY_TIMEOUT_MS=900000     # 15 min
# PIPELINE_FINALIZATION_TIMEOUT_MS=300000 # 5 min

# ─── AI Circuit Breaker (P4) ───
# Consecutive failures before opening circuit (default 3). Higher = more tolerant.
# CIRCUIT_BREAKER_THRESHOLD=3
# Cooldown in ms before allowing probe calls (default 60000 = 1 min).
# CIRCUIT_BREAKER_COOLDOWN_MS=60000
# Successful probes required to close circuit (default 1).
# CIRCUIT_BREAKER_PROBES=1

# ─── Worker Memory Monitor (P5) ───
# RSS growth % over window to trigger leak alert (default 50).
# MEMORY_ALERT_THRESHOLD_PCT=50
# Window in ms for growth measurement (default 3600000 = 1 hour).
# MEMORY_ALERT_WINDOW_MS=3600000
# Snapshot interval