# Normalize line endings — prevents CRLF↔LF round-trip commits on mixed-OS teams.
# Without this, Windows checkouts with core.autocrlf=true produce diffs the size
# of the repo every time a file is touched (see commit ab9af5d on branch
# claude/lucid-driscoll-f31002: 732 files, 236k+ / 236k- with zero real changes).

* text=auto eol=lf

# Shell + POSIX scripts must stay LF — CRLF breaks them in containers.
*.sh text eol=lf
docker-entrypoint.sh text eol=lf
*.bash text eol=lf

# Windows-only scripts keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never diff, never line-end-convert.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.mp4 binary
*.mov binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
