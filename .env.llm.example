# GCP / Vertex AI / Google Cloud Storage Configuration
# Copy to .env.llm and fill in your values.
# All are OPTIONAL — the pipeline degrades gracefully when unset.
#
# Fine-tuning pipeline requires all four GCP variables to be set:
#   GCP_PROJECT_ID     — GCP project that owns the Vertex AI and GCS resources
#   GCP_REGION         — region where Vertex AI tuning jobs run (e.g. us-central1)
#   GCS_TRAINING_BUCKET — GCS bucket where JSONL training files are stored
#   GOOGLE_APPLICATION_CREDENTIALS — path to a service account JSON key file.
#                        If unset, Application Default Credentials (ADC) are used,
#                        which works on GCP-hosted environments (Cloud Run, GCE, etc.)
#
# Lesson embedding index requires:
#   OPENAI_API_KEY     — used to generate text-embedding-3-small embeddings for
#                        pipeline lessons. When set, new lessons are automatically
#                        embedded on creation and buildLessonsPromptBlock() will
#                        perform semantic similarity retrieval in addition to the
#                        standard letter-type / jurisdiction filter.

GCP_PROJECT_ID=
GCP_REGION=us-central1
GCS_TRAINING_BUCKET=ttml-training
GOOGLE_APPLICATION_CREDENTIALS=
OPENAI_API_KEY=

# Vertex AI Vector Search (ANN) — optional, pgvector is used as fallback when unset
# The service account in GOOGLE_APPLICATION_CREDENTIALS must have the following roles:
#   - roles/aiplatform.user         (to query the index endpoint / findNeighbors)
#   - roles/aiplatform.indexAdmin   (to upsert datapoints to the index)
# Create the index with algorithm_config.tree_ah_config and streaming_update=true (STREAM_UPDATE).
VERTEX_SEARCH_INDEX_ID=
VERTEX_SEARCH_INDEX_ENDPOINT_ID=
VERTEX_SEARCH_DEPLOYED_INDEX_ID=
