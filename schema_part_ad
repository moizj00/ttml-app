-- 1. Add role-specific human-readable IDs to users table
ALTER TABLE users
  ADD COLUMN IF NOT EXISTS subscriber_id VARCHAR(16) UNIQUE,
  ADD COLUMN IF NOT EXISTS employee_id VARCHAR(16) UNIQUE,
