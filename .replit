modules = ["nodejs-20", "python-3.12", "web", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_database:1.0.0", "github:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["chromium"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Pipeline Worker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "full test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "new only"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "run with verbose output"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "review workflow test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Pipeline Orchestration Test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "run un watch mode"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=development npx tsx watch --import ./server/instrument.ts server/_core/index.ts"
waitForPort = 5000

[[workflows.workflow]]
name = "Pipeline Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=development npx tsx server/worker.ts"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "full test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx vitest run"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "new only"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx vitest run server/review-approval-flow.test.ts server/pipeline-pdf-email.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "run with verbose output"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx vitest run --reporter=verbose"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "review workflow test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx vitest run -t \"Review & Approval Flow\""

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "Pipeline Orchestration Test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx vitest run -t \"Pipeline Orchestration\""

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "run un watch mode"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx vitest"

[workflows.workflow.metadata]
isValidation = true

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 23636
externalPort = 80

[[ports]]
localPort = 23637
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["node", "--import", "./dist/instrument.js", "./dist/index.js"]
build = ["npm", "run", "build"]

[userenv]

[userenv.shared]
PORT = "5000"
GCP_PROJECT_ID = "ttml-488901-n8"
GCP_REGION = "us-west1"
GCS_TRAINING_BUCKET = "ttml-training"
R2_BUCKET_NAME = "talk-to-my-lawyer"
SENTRY_ORG = "gnzsolutions"
SENTRY_PROJECT = "node-express"
GOOGLE_APPLICATION_CREDENTIALS = "/home/runner/workspace/server/gcp-credentials.json"

[userenv.production]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[rules]

[rules.formatter]

[rules.formatter.fileExtensions]

[rules.formatter.fileExtensions.".tsx"]
id = "module:nodejs-20/formatter:prettier"
